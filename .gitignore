# This repository is a publishing example. Ignore everything by default, then
# allow only the docs, workflows, and sample source/build files that explain or
# exercise Modtale publishing.
*

!.gitignore
!README.md
!api-recipes.md
!logo.svg
!settings.gradle

!.github/
!.github/workflows/
!.github/workflows/*.yml

!go-publisher/
!go-publisher/go.mod
!go-publisher/main.go

!gradle-plugin/
!gradle-plugin/settings.gradle
!gradle-plugin/build.gradle
!gradle-plugin/src/
!gradle-plugin/src/main/
!gradle-plugin/src/main/java/
!gradle-plugin/src/main/java/net/
!gradle-plugin/src/main/java/net/example/
!gradle-plugin/src/main/java/net/example/*.java

!gradle-maven-dependency/
!gradle-maven-dependency/settings.gradle
!gradle-maven-dependency/build.gradle
!gradle-maven-dependency/src/
!gradle-maven-dependency/src/main/
!gradle-maven-dependency/src/main/java/
!gradle-maven-dependency/src/main/java/net/
!gradle-maven-dependency/src/main/java/net/example/
!gradle-maven-dependency/src/main/java/net/example/*.java

!maven-plugin/
!maven-plugin/pom.xml
!maven-plugin/src/
!maven-plugin/src/main/
!maven-plugin/src/main/java/
!maven-plugin/src/main/java/net/
!maven-plugin/src/main/java/net/example/
!maven-plugin/src/main/java/net/example/*.java

!resource-pack/
!resource-pack/README.md
